# Copy this file to `.env` when testing the GitHub App locally through ngrok.
# Replace the placeholder ngrok URLs with your real public HTTPS tunnel URLs.

DATABASE_URL=postgresql://praxis:praxis@127.0.0.1:5432/praxis?schema=public
PORT=4848
HOST=127.0.0.1
PRAXIS_PROXY_HOST=127.0.0.1
PRAXIS_PROXY_PORT=8080
PRAXIS_LOCAL_API_ORIGIN=http://127.0.0.1:4848
PRAXIS_LOCAL_WEB_ORIGIN=http://127.0.0.1:3000

# Local dev fallback store. Ignored by the API when DATABASE_URL is set.
PRAXIS_API_STORE=tmp/praxis-api-store.json

# One public URL that GitHub can reach. The local proxy fans this out to the API
# and the web app.
PRAXIS_API_BASE_URL=https://your-subdomain.ngrok-free.app
PRAXIS_WEB_BASE_URL=https://your-subdomain.ngrok-free.app

# Next.js client-side URLs. Keep these aligned with the public proxy URL.
NEXT_PUBLIC_PRAXIS_API_BASE_URL=https://your-subdomain.ngrok-free.app
NEXT_PUBLIC_PRAXIS_WEB_BASE_URL=https://your-subdomain.ngrok-free.app

# Optional explicit browser origin allowlist for direct API calls.
# Leave unset to derive allowed origins from the web base URL and local dev defaults.
PRAXIS_WEB_CORS_ORIGINS=

# GitHub App credentials.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=

# Optional template repository used during `praxis setup`.
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# Copy this file to `.env` when testing the GitHub App locally through ngrok.
# Replace the placeholder ngrok URLs with your real public HTTPS tunnel URLs.

DATABASE_URL=postgresql://nibras:nibras@127.0.0.1:5432/nibras?schema=public
PORT=4848
HOST=127.0.0.1
NIBRAS_PROXY_HOST=127.0.0.1
NIBRAS_PROXY_PORT=8080
NIBRAS_LOCAL_API_ORIGIN=http://127.0.0.1:4848
NIBRAS_LOCAL_WEB_ORIGIN=http://127.0.0.1:3000

# Local dev fallback store. Ignored by the API when DATABASE_URL is set.
NIBRAS_API_STORE=tmp/nibras-api-store.json

# One public URL that GitHub can reach. The local proxy fans this out to the API
# and the web app.
NIBRAS_API_BASE_URL=https://your-subdomain.ngrok-free.app
NIBRAS_WEB_BASE_URL=https://your-subdomain.ngrok-free.app

# Next.js client-side URLs. Keep these aligned with the public proxy URL.
NEXT_PUBLIC_NIBRAS_API_BASE_URL=https://your-subdomain.ngrok-free.app
NEXT_PUBLIC_NIBRAS_WEB_BASE_URL=https://your-subdomain.ngrok-free.app

# Optional explicit browser origin allowlist for direct API calls.
# Leave unset to derive allowed origins from the web base URL and local dev defaults.
NIBRAS_WEB_CORS_ORIGINS=

# GitHub App credentials.
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=

# Optional template repository used during `nibras setup`.
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

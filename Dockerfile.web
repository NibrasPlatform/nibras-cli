FROM node:20-alpine AS base
WORKDIR /app

# ── Install dependencies ───────────────────────────────────────────────────────
FROM base AS deps
COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY packages/contracts/package.json ./packages/contracts/
RUN npm ci --workspace=@nibras/web --workspace=@nibras/contracts --include-workspace-root

# ── Build ──────────────────────────────────────────────────────────────────────
FROM deps AS build
COPY packages/contracts ./packages/contracts
COPY apps/web ./apps/web
COPY tsconfig.base.json ./
# Build-time public vars must be baked in at image build time for Next.js
ARG NEXT_PUBLIC_NIBRAS_API_BASE_URL
ARG NEXT_PUBLIC_NIBRAS_WEB_BASE_URL
ENV NEXT_PUBLIC_NIBRAS_API_BASE_URL=$NEXT_PUBLIC_NIBRAS_API_BASE_URL
ENV NEXT_PUBLIC_NIBRAS_WEB_BASE_URL=$NEXT_PUBLIC_NIBRAS_WEB_BASE_URL
RUN npm run build -w @nibras/web

# ── Runtime ────────────────────────────────────────────────────────────────────
FROM base AS runner
ENV NODE_ENV=production
COPY --from=build /app/node_modules ./node_modules
COPY --from=build /app/apps/web/.next ./apps/web/.next
COPY --from=build /app/apps/web/public ./apps/web/public
COPY --from=build /app/apps/web/package.json ./apps/web/
COPY package.json ./

EXPOSE 3000
CMD ["node", "apps/web/node_modules/.bin/next", "start", "--port", "3000", "-H", "0.0.0.0"]

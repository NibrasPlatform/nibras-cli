generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  queued
  running
  passed
  failed
  needs_review
}

enum SystemRole {
  user
  admin
}

enum CourseRole {
  student
  instructor
  ta
}

enum ProjectStatus {
  draft
  published
  archived
}

enum DeliveryMode {
  individual
  team
}

enum TrackingSubmissionType {
  github
  link
  text
}

enum ReviewStatus {
  pending
  approved
  changes_requested
  graded
}

enum RepoVisibility {
  private
  public
}

enum AssetVisibility {
  public
  private
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  email             String             @unique
  githubLinked      Boolean            @default(false)
  githubAppInstalled Boolean           @default(false)
  systemRole        SystemRole         @default(user)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  githubAccount     GithubAccount?
  courseMemberships CourseMembership[]
  deviceCodes       DeviceCode[]
  cliSessions       CliSession[]
  webSessions       WebSession[]
  userProjectRepos  UserProjectRepo[]
  submissionAttempts SubmissionAttempt[]
  auditLogs         AuditLog[]
  reviews           Review[]

  @@index([systemRole])
}

model Course {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String
  termLabel   String
  courseCode  String
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memberships CourseMembership[]
  projects    Project[]
  invites     CourseInvite[]
  auditLogs   AuditLog[]
}

model CourseInvite {
  id        String      @id @default(cuid())
  courseId  String
  code      String      @unique
  role      CourseRole  @default(student)
  maxUses   Int         @default(0)
  useCount  Int         @default(0)
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseMembership {
  id         String     @id @default(cuid())
  courseId   String
  userId     String
  role       CourseRole
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model GithubAccount {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  githubUserId              String   @unique
  login                     String
  installationId            String?
  userAccessToken           String?
  userRefreshToken          String?
  userAccessTokenExpiresAt  DateTime?
  userRefreshTokenExpiresAt DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceCode {
  id              String   @id @default(cuid())
  deviceCode      String   @unique
  userCode        String   @unique
  expiresAt       DateTime
  intervalSeconds Int
  status          String
  userId          String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CliSession {
  id            String    @id @default(cuid())
  accessToken   String    @unique
  refreshToken  String    @unique
  userId        String
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subject {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id               String            @id @default(cuid())
  subjectId        String
  courseId         String?
  slug             String            @unique
  name             String
  defaultBranch    String            @default("main")
  description      String            @default("")
  status           ProjectStatus     @default(draft)
  deliveryMode     DeliveryMode      @default(individual)
  rubricJson       Json?
  resourcesJson    Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  course           Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  releases         ProjectRelease[]
  milestones       Milestone[]
  userProjectRepos UserProjectRepo[]
  submissions      SubmissionAttempt[]
  auditLogs        AuditLog[]
}

model ProjectRelease {
  id               String         @id @default(cuid())
  projectId        String
  version          String
  taskText         String
  manifestJson     Json
  publicAssetRef   String?
  privateAssetRef  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets           ProjectAsset[]
  submissions      SubmissionAttempt[]

  @@unique([projectId, version])
}

model ProjectAsset {
  id                String          @id @default(cuid())
  projectReleaseId  String
  visibility        AssetVisibility
  kind              String
  storageKey        String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  projectRelease    ProjectRelease  @relation(fields: [projectReleaseId], references: [id], onDelete: Cascade)
}

model UserProjectRepo {
  id              String         @id @default(cuid())
  userId          String
  projectId       String
  owner           String
  name            String
  githubRepoId    String?
  cloneUrl        String?
  defaultBranch   String
  visibility      RepoVisibility @default(private)
  installStatus   String         @default("provisioned")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions     SubmissionAttempt[]

  @@unique([userId, projectId])
}

model SubmissionAttempt {
  id               String            @id @default(cuid())
  userId           String
  projectId        String
  projectReleaseId String
  userProjectRepoId String
  milestoneId      String?
  commitSha        String
  repoUrl          String
  branch           String
  status           SubmissionStatus  @default(queued)
  summary          String
  submissionType   TrackingSubmissionType @default(github)
  submissionValue  String?
  notes            String?
  submittedAt      DateTime?
  localTestExitCode Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectRelease   ProjectRelease    @relation(fields: [projectReleaseId], references: [id], onDelete: Cascade)
  userProjectRepo  UserProjectRepo   @relation(fields: [userProjectRepoId], references: [id], onDelete: Cascade)
  milestone        Milestone?        @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  reviews           Review[]
  githubDeliveries  GithubDelivery[]
  auditLogs         AuditLog[]
  verificationRuns  VerificationRun[]
  verificationJob   VerificationJob?

  @@unique([userId, projectId, commitSha])
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([milestoneId])
}

model Milestone {
  id          String              @id @default(cuid())
  projectId   String
  title       String
  description String             @default("")
  order       Int
  dueAt       DateTime?
  isFinal     Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions SubmissionAttempt[]
  auditLogs   AuditLog[]

  @@unique([projectId, order])
}

model Review {
  id                   String            @id @default(cuid())
  submissionAttemptId  String
  reviewerUserId       String
  status               ReviewStatus
  score                Float?
  feedback             String            @default("")
  rubricJson           Json?
  reviewedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  // AI grading fields (nullable — populated by worker when AI config is present)
  aiConfidence         Float?
  aiNeedsReview        Boolean?
  aiReasoningSummary   String?
  aiCriterionScores    Json?
  aiEvidenceQuotes     Json?
  aiModel              String?
  aiGradedAt           DateTime?
  submissionAttempt    SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)
  reviewer             User              @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)
}

model GithubDelivery {
  id                  String            @id @default(cuid())
  submissionAttemptId String
  repoUrl             String
  eventType           String
  deliveryId          String
  ref                 String
  commitSha           String
  payloadJson         Json?
  receivedAt          DateTime          @default(now())
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@unique([deliveryId])
}

model VerificationRun {
  id                  String            @id @default(cuid())
  submissionAttemptId String
  attempt             Int               @default(0)
  status              SubmissionStatus  @default(queued)
  log                 String
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@unique([submissionAttemptId, attempt])
}

model VerificationJob {
  id                  String            @id @default(cuid())
  submissionAttemptId String            @unique
  traceId             String            @default(cuid())
  status              SubmissionStatus  @default(queued)
  attempt             Int               @default(0)
  maxAttempts         Int               @default(3)
  claimedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@index([status, claimedAt, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  courseId   String?
  projectId  String?
  milestoneId String?
  submissionAttemptId String?
  action     String
  targetType String
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestone  Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  submissionAttempt SubmissionAttempt? @relation(fields: [submissionAttemptId], references: [id], onDelete: SetNull)
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SubmissionStatus {
  queued
  running
  passed
  failed
  needs_review
}

enum SystemRole {
  user
  admin
}

enum CourseRole {
  student
  instructor
  ta
}

enum ProjectStatus {
  draft
  published
  archived
}

enum DeliveryMode {
  individual
  team
}

enum ProjectTemplateStatus {
  draft
  active
}

enum TeamFormationStatus {
  not_started
  application_open
  team_review
  teams_locked
}

enum ProjectRoleApplicationStatus {
  submitted
  withdrawn
}

enum TeamStatus {
  suggested
  locked
}

enum TrackingSubmissionType {
  github
  link
  text
}

enum ReviewStatus {
  pending
  approved
  changes_requested
  graded
}

enum ProgramStatus {
  draft
  published
  archived
}

enum RequirementGroupCategory {
  foundation
  core
  depth
  elective
  capstone
  policy
}

enum RequirementRuleType {
  required
  choose_n
  elective_pool
  track_gate
}

enum StudentProgramStatus {
  enrolled
  track_selected
  submitted_for_advisor
  advisor_approved
  department_approved
}

enum PlannedCourseSourceType {
  standard
  transfer
  petition
  manual
}

enum StudentRequirementDecisionStatus {
  pending
  satisfied
  waived
  petition_pending
}

enum RequirementDecisionSourceType {
  planned_course
  transfer_credit
  petition
  waiver
}

enum PetitionType {
  transfer_credit
  substitution
  waiver
}

enum PetitionStatus {
  pending_advisor
  pending_department
  approved
  rejected
}

enum ApprovalStage {
  advisor
  department
}

enum ApprovalStatus {
  pending
  approved
  rejected
}

enum AcademicTerm {
  fall
  spring
}

enum RepoVisibility {
  private
  public
}

enum AssetVisibility {
  public
  private
}

model User {
  id                String             @id @default(cuid())
  username          String             @unique
  email             String             @unique
  githubLinked      Boolean            @default(false)
  githubAppInstalled Boolean           @default(false)
  systemRole        SystemRole         @default(user)
  yearLevel         Int                @default(1)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  githubAccount     GithubAccount?
  courseMemberships CourseMembership[]
  deviceCodes       DeviceCode[]
  cliSessions       CliSession[]
  webSessions       WebSession[]
  userProjectRepos  UserProjectRepo[]
  submissionAttempts SubmissionAttempt[]
  submittedAttempts SubmissionAttempt[] @relation("SubmissionSubmittedBy")
  auditLogs         AuditLog[]
  reviews           Review[]
  notifications     Notification[]
  projectRoleApplications ProjectRoleApplication[]
  teamMembers       TeamMember[]
  createdTeamFormationRuns TeamFormationRun[]
  studentPrograms   StudentProgram[]
  submittedPetitions Petition[]        @relation("ProgramPetitionSubmitter")
  reviewedPetitions Petition[]         @relation("ProgramPetitionReviewer")
  reviewedProgramApprovals ProgramApproval[]

  @@index([systemRole])
  @@index([yearLevel])
}

model Course {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String
  termLabel   String
  courseCode  String
  isActive    Boolean            @default(true)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  memberships CourseMembership[]
  projects    Project[]
  projectTemplates ProjectTemplate[]
  invites     CourseInvite[]
  auditLogs   AuditLog[]
}

model CourseInvite {
  id        String      @id @default(cuid())
  courseId  String
  code      String      @unique
  role      CourseRole  @default(student)
  maxUses   Int         @default(0)
  useCount  Int         @default(0)
  expiresAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  course    Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model CourseMembership {
  id         String     @id @default(cuid())
  courseId   String
  userId     String
  role       CourseRole
  level      Int        @default(1)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
}

model Program {
  id                   String            @id @default(cuid())
  slug                 String            @unique
  title                String
  code                 String
  academicYear         String
  totalUnitRequirement Int
  status               ProgramStatus     @default(draft)
  activeVersionId      String?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  versions             ProgramVersion[]
  catalogCourses       CatalogCourse[]
}

model ProgramVersion {
  id                     String            @id @default(cuid())
  programId              String
  versionLabel           String
  effectiveFrom          DateTime?
  effectiveTo            DateTime?
  isActive               Boolean           @default(false)
  policyText             String            @default("")
  trackSelectionMinYear  Int               @default(2)
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  program                Program           @relation(fields: [programId], references: [id], onDelete: Cascade)
  tracks                 Track[]
  requirementGroups      RequirementGroup[]
  studentPrograms        StudentProgram[]
  sheetSnapshots         ProgramSheetSnapshot[]

  @@index([programId, isActive])
}

model Track {
  id                  String             @id @default(cuid())
  programVersionId    String
  slug                String
  title               String
  description         String             @default("")
  selectionYearStart  Int                @default(2)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  programVersion      ProgramVersion     @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  requirementGroups   RequirementGroup[]
  selectedByStudents  StudentProgram[]

  @@unique([programVersionId, slug])
}

model CatalogCourse {
  id                     String               @id @default(cuid())
  programId              String
  subjectCode            String
  catalogNumber          String
  title                  String
  defaultUnits           Int
  department             String
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  program                Program              @relation(fields: [programId], references: [id], onDelete: Cascade)
  requirementCourses     RequirementCourse[]
  studentPlannedCourses  StudentPlannedCourse[]
  originalPetitionLinks  PetitionCourseLink[] @relation("OriginalPetitionCourse")
  substitutePetitionLinks PetitionCourseLink[] @relation("SubstitutePetitionCourse")

  @@unique([programId, subjectCode, catalogNumber])
}

model RequirementGroup {
  id                String                @id @default(cuid())
  programVersionId  String
  trackId           String?
  title             String
  category          RequirementGroupCategory
  minUnits          Int                   @default(0)
  minCourses        Int                   @default(0)
  notes             String                @default("")
  sortOrder         Int                   @default(0)
  noDoubleCount     Boolean               @default(true)
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  programVersion    ProgramVersion        @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  track             Track?                @relation(fields: [trackId], references: [id], onDelete: SetNull)
  rules             RequirementRule[]
  decisions         StudentRequirementDecision[]
  petitions         Petition[]

  @@index([programVersionId, trackId, sortOrder])
}

model RequirementRule {
  id                  String             @id @default(cuid())
  requirementGroupId  String
  ruleType            RequirementRuleType
  pickCount           Int?
  note                String             @default("")
  sortOrder           Int                @default(0)
  requirementGroup    RequirementGroup   @relation(fields: [requirementGroupId], references: [id], onDelete: Cascade)
  courses             RequirementCourse[]

  @@index([requirementGroupId, sortOrder])
}

model RequirementCourse {
  id                 String           @id @default(cuid())
  requirementRuleId  String
  catalogCourseId    String
  requirementRule    RequirementRule  @relation(fields: [requirementRuleId], references: [id], onDelete: Cascade)
  catalogCourse      CatalogCourse    @relation(fields: [catalogCourseId], references: [id], onDelete: Cascade)

  @@unique([requirementRuleId, catalogCourseId])
}

model StudentProgram {
  id              String                       @id @default(cuid())
  userId          String
  programVersionId String
  selectedTrackId String?
  status          StudentProgramStatus        @default(enrolled)
  isLocked        Boolean                     @default(false)
  createdAt       DateTime                    @default(now())
  updatedAt       DateTime                    @updatedAt
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  programVersion  ProgramVersion              @relation(fields: [programVersionId], references: [id], onDelete: Cascade)
  selectedTrack   Track?                      @relation(fields: [selectedTrackId], references: [id], onDelete: SetNull)
  plannedCourses  StudentPlannedCourse[]
  decisions       StudentRequirementDecision[]
  petitions       Petition[]
  approvals       ProgramApproval[]
  sheetSnapshots  ProgramSheetSnapshot[]

  @@index([userId, programVersionId])
}

model StudentPlannedCourse {
  id               String                  @id @default(cuid())
  studentProgramId String
  catalogCourseId  String
  plannedYear      Int
  plannedTerm      AcademicTerm
  sourceType       PlannedCourseSourceType @default(standard)
  note             String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  studentProgram   StudentProgram          @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  catalogCourse    CatalogCourse           @relation(fields: [catalogCourseId], references: [id], onDelete: Cascade)

  @@index([studentProgramId, plannedYear, plannedTerm])
}

model StudentRequirementDecision {
  id                String                          @id @default(cuid())
  studentProgramId  String
  requirementGroupId String
  status            StudentRequirementDecisionStatus
  sourceType        RequirementDecisionSourceType?
  notes             String?
  createdAt         DateTime                        @default(now())
  updatedAt         DateTime                        @updatedAt
  studentProgram    StudentProgram                  @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  requirementGroup  RequirementGroup                @relation(fields: [requirementGroupId], references: [id], onDelete: Cascade)

  @@unique([studentProgramId, requirementGroupId])
}

model Petition {
  id                     String          @id @default(cuid())
  studentProgramId       String
  type                   PetitionType
  status                 PetitionStatus  @default(pending_advisor)
  justification          String
  targetRequirementGroupId String?
  submittedByUserId      String
  reviewerUserId         String?
  reviewerNotes          String?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  studentProgram         StudentProgram  @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  targetRequirementGroup RequirementGroup? @relation(fields: [targetRequirementGroupId], references: [id], onDelete: SetNull)
  submittedByUser        User            @relation("ProgramPetitionSubmitter", fields: [submittedByUserId], references: [id], onDelete: Cascade)
  reviewerUser           User?           @relation("ProgramPetitionReviewer", fields: [reviewerUserId], references: [id], onDelete: SetNull)
  courseLinks            PetitionCourseLink[]
}

model PetitionCourseLink {
  id                       String        @id @default(cuid())
  petitionId               String
  originalCatalogCourseId  String?
  substituteCatalogCourseId String?
  petition                 Petition      @relation(fields: [petitionId], references: [id], onDelete: Cascade)
  originalCatalogCourse    CatalogCourse? @relation("OriginalPetitionCourse", fields: [originalCatalogCourseId], references: [id], onDelete: SetNull)
  substituteCatalogCourse  CatalogCourse? @relation("SubstitutePetitionCourse", fields: [substituteCatalogCourseId], references: [id], onDelete: SetNull)
}

model ProgramApproval {
  id               String         @id @default(cuid())
  studentProgramId String
  stage            ApprovalStage
  status           ApprovalStatus @default(pending)
  reviewerUserId   String?
  notes            String?
  decidedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  reviewerUser     User?          @relation(fields: [reviewerUserId], references: [id], onDelete: SetNull)

  @@unique([studentProgramId, stage])
}

model ProgramSheetSnapshot {
  id               String         @id @default(cuid())
  studentProgramId String
  versionId        String
  renderedPayload  Json
  generatedAt      DateTime       @default(now())
  studentProgram   StudentProgram @relation(fields: [studentProgramId], references: [id], onDelete: Cascade)
  version          ProgramVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@index([studentProgramId, generatedAt])
}

model GithubAccount {
  id                        String   @id @default(cuid())
  userId                    String   @unique
  githubUserId              String   @unique
  login                     String
  installationId            String?
  userAccessToken           String?
  userRefreshToken          String?
  userAccessTokenExpiresAt  DateTime?
  userRefreshTokenExpiresAt DateTime?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DeviceCode {
  id              String   @id @default(cuid())
  deviceCode      String   @unique
  userCode        String   @unique
  expiresAt       DateTime
  intervalSeconds Int
  status          String
  userId          String?
  approvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model CliSession {
  id            String    @id @default(cuid())
  accessToken   String    @unique
  refreshToken  String    @unique
  userId        String
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  revokedAt     DateTime?
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WebSession {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  revokedAt    DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Subject {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  projects    Project[]
}

model Project {
  id               String            @id @default(cuid())
  subjectId        String
  courseId         String?
  templateId       String?
  slug             String            @unique
  name             String
  defaultBranch    String            @default("main")
  description      String            @default("")
  status           ProjectStatus     @default(draft)
  level            Int               @default(1)
  deliveryMode     DeliveryMode      @default(individual)
  applicationOpenAt DateTime?
  applicationCloseAt DateTime?
  teamLockAt       DateTime?
  teamFormationStatus TeamFormationStatus @default(not_started)
  rubricJson       Json?
  resourcesJson    Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  subject          Subject           @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  course           Course?           @relation(fields: [courseId], references: [id], onDelete: SetNull)
  template         ProjectTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  releases         ProjectRelease[]
  milestones       Milestone[]
  userProjectRepos UserProjectRepo[]
  submissions      SubmissionAttempt[]
  roleApplications ProjectRoleApplication[]
  teamFormationRuns TeamFormationRun[]
  teams            Team[]
  auditLogs        AuditLog[]
}

model ProjectTemplate {
  id          String               @id @default(cuid())
  courseId    String
  slug        String
  title       String
  description String              @default("")
  deliveryMode DeliveryMode       @default(team)
  teamSize    Int?
  status      ProjectTemplateStatus @default(active)
  rubricJson  Json?
  resourcesJson Json?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  course      Course              @relation(fields: [courseId], references: [id], onDelete: Cascade)
  roles       ProjectTemplateRole[]
  milestones  ProjectTemplateMilestone[]
  projects    Project[]

  @@unique([courseId, slug])
}

model ProjectTemplateRole {
  id         String          @id @default(cuid())
  templateId String
  key        String
  label      String
  count      Int             @default(1)
  sortOrder  Int             @default(0)
  template   ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  preferences ProjectRolePreference[]
}

model ProjectTemplateMilestone {
  id          String          @id @default(cuid())
  templateId  String
  title       String
  description String          @default("")
  order       Int
  dueAt       DateTime?
  isFinal     Boolean         @default(false)
  template    ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, order])
}

model ProjectRoleApplication {
  id               String                       @id @default(cuid())
  projectId        String
  userId           String
  statement        String                       @default("")
  availabilityNote String                       @default("")
  status           ProjectRoleApplicationStatus @default(submitted)
  submittedAt      DateTime?
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  project          Project                      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user             User                         @relation(fields: [userId], references: [id], onDelete: Cascade)
  preferences      ProjectRolePreference[]

  @@unique([projectId, userId])
}

model ProjectRolePreference {
  id              String                 @id @default(cuid())
  applicationId   String
  templateRoleId  String
  rank            Int
  application     ProjectRoleApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  templateRole    ProjectTemplateRole    @relation(fields: [templateRoleId], references: [id], onDelete: Cascade)

  @@unique([applicationId, rank])
}

model TeamFormationRun {
  id               String   @id @default(cuid())
  projectId        String
  algorithmVersion String
  configJson       Json
  resultJson       Json
  createdByUserId  String
  createdAt        DateTime @default(now())
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdByUser    User     @relation(fields: [createdByUserId], references: [id], onDelete: Cascade)
  teams            Team[]
}

model Team {
  id             String           @id @default(cuid())
  projectId      String
  name           String
  status         TeamStatus       @default(suggested)
  formationRunId String?
  lockedAt       DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  project        Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  formationRun   TeamFormationRun? @relation(fields: [formationRunId], references: [id], onDelete: SetNull)
  members        TeamMember[]
  repo           TeamProjectRepo?
  submissions    SubmissionAttempt[]
}

model TeamMember {
  id         String   @id @default(cuid())
  teamId      String
  userId      String
  roleKey     String
  roleLabel   String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
}

model TeamProjectRepo {
  id            String         @id @default(cuid())
  teamId        String         @unique
  owner         String
  name          String
  githubRepoId  String?
  cloneUrl      String?
  defaultBranch String
  visibility    RepoVisibility @default(private)
  installStatus String         @default("provisioned")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  team          Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  submissions   SubmissionAttempt[]
}

model ProjectRelease {
  id               String         @id @default(cuid())
  projectId        String
  version          String
  taskText         String
  manifestJson     Json
  publicAssetRef   String?
  privateAssetRef  String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assets           ProjectAsset[]
  submissions      SubmissionAttempt[]

  @@unique([projectId, version])
}

model ProjectAsset {
  id                String          @id @default(cuid())
  projectReleaseId  String
  visibility        AssetVisibility
  kind              String
  storageKey        String
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  projectRelease    ProjectRelease  @relation(fields: [projectReleaseId], references: [id], onDelete: Cascade)
}

model UserProjectRepo {
  id              String         @id @default(cuid())
  userId          String
  projectId       String
  owner           String
  name            String
  githubRepoId    String?
  cloneUrl        String?
  defaultBranch   String
  visibility      RepoVisibility @default(private)
  installStatus   String         @default("provisioned")
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  project         Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions     SubmissionAttempt[]

  @@unique([userId, projectId])
}

model SubmissionAttempt {
  id               String            @id @default(cuid())
  userId           String
  submittedByUserId String?
  projectId        String
  projectReleaseId String
  userProjectRepoId String?
  teamId           String?
  teamProjectRepoId String?
  milestoneId      String?
  commitSha        String
  repoUrl          String
  branch           String
  status           SubmissionStatus  @default(queued)
  summary          String
  submissionType   TrackingSubmissionType @default(github)
  submissionValue  String?
  notes            String?
  submittedAt      DateTime?
  localTestExitCode Int?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  submittedByUser  User?             @relation("SubmissionSubmittedBy", fields: [submittedByUserId], references: [id], onDelete: SetNull)
  project          Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectRelease   ProjectRelease    @relation(fields: [projectReleaseId], references: [id], onDelete: Cascade)
  userProjectRepo  UserProjectRepo?  @relation(fields: [userProjectRepoId], references: [id], onDelete: Cascade)
  team             Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull)
  teamProjectRepo  TeamProjectRepo?  @relation(fields: [teamProjectRepoId], references: [id], onDelete: SetNull)
  milestone        Milestone?        @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  reviews           Review[]
  githubDeliveries  GithubDelivery[]
  auditLogs         AuditLog[]
  verificationRuns  VerificationRun[]
  verificationJob   VerificationJob?

  @@unique([userId, projectId, commitSha])
  @@index([userId])
  @@index([projectId])
  @@index([status])
  @@index([milestoneId])
  @@index([teamId])
}

model Milestone {
  id          String              @id @default(cuid())
  projectId   String
  title       String
  description String             @default("")
  order       Int
  dueAt       DateTime?
  isFinal     Boolean            @default(false)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  project     Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  submissions SubmissionAttempt[]
  auditLogs   AuditLog[]

  @@unique([projectId, order])
}

model Review {
  id                   String            @id @default(cuid())
  submissionAttemptId  String
  reviewerUserId       String
  status               ReviewStatus
  score                Float?
  feedback             String            @default("")
  rubricJson           Json?
  reviewedAt           DateTime?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  // AI grading fields (nullable — populated by worker when AI config is present)
  aiConfidence         Float?
  aiNeedsReview        Boolean?
  aiReasoningSummary   String?
  aiCriterionScores    Json?
  aiEvidenceQuotes     Json?
  aiModel              String?
  aiGradedAt           DateTime?
  submissionAttempt    SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)
  reviewer             User              @relation(fields: [reviewerUserId], references: [id], onDelete: Cascade)
}

model GithubDelivery {
  id                  String            @id @default(cuid())
  submissionAttemptId String
  repoUrl             String
  eventType           String
  deliveryId          String
  ref                 String
  commitSha           String
  payloadJson         Json?
  receivedAt          DateTime          @default(now())
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@unique([deliveryId])
}

model VerificationRun {
  id                  String            @id @default(cuid())
  submissionAttemptId String
  attempt             Int               @default(0)
  status              SubmissionStatus  @default(queued)
  log                 String
  startedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@unique([submissionAttemptId, attempt])
}

model VerificationJob {
  id                  String            @id @default(cuid())
  submissionAttemptId String            @unique
  traceId             String            @default(cuid())
  status              SubmissionStatus  @default(queued)
  attempt             Int               @default(0)
  maxAttempts         Int               @default(3)
  claimedAt           DateTime?
  finishedAt          DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  submissionAttempt   SubmissionAttempt @relation(fields: [submissionAttemptId], references: [id], onDelete: Cascade)

  @@index([status, claimedAt, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  courseId   String?
  projectId  String?
  milestoneId String?
  submissionAttemptId String?
  action     String
  targetType String
  targetId   String
  payload    Json?
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  course     Course?  @relation(fields: [courseId], references: [id], onDelete: SetNull)
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  milestone  Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  submissionAttempt SubmissionAttempt? @relation(fields: [submissionAttemptId], references: [id], onDelete: SetNull)
}

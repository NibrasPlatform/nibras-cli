# Production environment — copy to .env.prod and fill in values.
# Never commit this file with real secrets.

# --- Database ---
DATABASE_URL=postgresql://praxis:CHANGEME@localhost:5432/praxis
POSTGRES_USER=praxis
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=praxis

# --- API ---
NODE_ENV=production
PRAXIS_API_BASE_URL=https://api.yourdomain.com
PRAXIS_WEB_BASE_URL=https://yourdomain.com

# Session & encryption keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
PRAXIS_SESSION_SECRET=CHANGEME_32_BYTE_HEX
PRAXIS_ENCRYPTION_KEY=CHANGEME_32_BYTE_HEX

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=CHANGEME
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# --- Optional ---
PRAXIS_ENABLE_DEMO_SEED=0
WORKER_POLL_INTERVAL_MS=2000

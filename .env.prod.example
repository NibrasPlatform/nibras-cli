# Production environment template — copy to .env and fill in all values.
# Never commit this file with real secrets.
# Generate random secrets with: openssl rand -hex 32

# ── Database (required) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://nibras:CHANGEME@db:5432/nibras
POSTGRES_USER=nibras
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=nibras

# ── Server (required) ─────────────────────────────────────────────────────────
NODE_ENV=production
# Bind to 0.0.0.0 so the container is reachable from outside (required).
HOST=0.0.0.0
PORT=4848
NIBRAS_API_BASE_URL=https://api.yourdomain.com
NIBRAS_WEB_BASE_URL=https://yourdomain.com
# Must match NIBRAS_WEB_BASE_URL — used by Next.js client-side code.
NEXT_PUBLIC_NIBRAS_API_BASE_URL=https://api.yourdomain.com
NEXT_PUBLIC_NIBRAS_WEB_BASE_URL=https://yourdomain.com

# ── Encryption (required) ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
NIBRAS_ENCRYPTION_KEY=CHANGEME_32_BYTE_HEX

# ── GitHub App (required for login and webhooks) ──────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
# PEM private key — encode newlines as \n for single-line env vars:
#   awk 'NF {sub(/\r/, ""); printf "%s\\n",$0;}' your-key.pem
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=CHANGEME
# Template repo that gets forked for each student project (optional).
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# ── Redis / BullMQ (optional) ─────────────────────────────────────────────────
# When set, jobs are dispatched instantly via Redis instead of DB polling.
# Format: redis://[:password@]host:port  or  rediss://... for TLS
REDIS_URL=

# ── Worker (optional — defaults shown) ───────────────────────────────────────
# Parallel job slots. Increase if your machine has CPU headroom.
WORKER_CONCURRENCY=1
# DB polling interval when REDIS_URL is not set (milliseconds).
WORKER_POLL_INTERVAL_MS=2000
# Internal health check port — must match Dockerfile.worker EXPOSE.
WORKER_HEALTH_PORT=9090
# Sandbox mode: 'ulimit' enforces CPU/memory limits; 'none' disables them.
WORKER_SANDBOX_MODE=ulimit
# Maximum CPU seconds per student verification run.
WORKER_MAX_CPU_SECONDS=60
# Maximum virtual memory in MB per student verification run.
WORKER_MAX_MEM_MB=512

# ── Email notifications (optional) ───────────────────────────────────────────
# Get a free API key at resend.com. When unset, emails are silently skipped.
RESEND_API_KEY=
# Must be a verified sender domain in your Resend account.
NIBRAS_EMAIL_FROM=Nibras <noreply@yourdomain.com>

# ── Error monitoring (optional) ───────────────────────────────────────────────
# When set, the API and worker report errors to Sentry automatically.
SENTRY_DSN=

# ── AI Grading (optional) ─────────────────────────────────────────────────────
# Set both vars to enable AI semantic grading after successful test runs.
# Omit to disable entirely — no breaking change.
NIBRAS_AI_API_KEY=
NIBRAS_AI_MODEL=gpt-4o-mini
# Override for compatible providers (Azure OpenAI, Ollama, etc.)
NIBRAS_AI_BASE_URL=https://api.openai.com/v1
NIBRAS_AI_TIMEOUT_MS=30000
NIBRAS_AI_MAX_RETRIES=2
# Submissions with AI confidence below this threshold are flagged for human review.
NIBRAS_AI_MIN_CONFIDENCE=0.8

# ── Observability (optional) ──────────────────────────────────────────────────
# Bearer token to protect the /metrics Prometheus endpoint.
# Leave unset to disable auth on /metrics (only do this on private networks).
NIBRAS_METRICS_TOKEN=
# Fastify log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=warn

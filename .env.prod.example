# Production environment — copy to .env.prod and fill in values.
# Never commit this file with real secrets.

# --- Database ---
DATABASE_URL=postgresql://nibras:CHANGEME@localhost:5432/nibras
POSTGRES_USER=nibras
POSTGRES_PASSWORD=CHANGEME
POSTGRES_DB=nibras

# --- API ---
NODE_ENV=production
NIBRAS_API_BASE_URL=https://api.yourdomain.com
NIBRAS_WEB_BASE_URL=https://yourdomain.com

# Session & encryption keys (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
NIBRAS_SESSION_SECRET=CHANGEME_32_BYTE_HEX
NIBRAS_ENCRYPTION_KEY=CHANGEME_32_BYTE_HEX

# --- GitHub App ---
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=CHANGEME
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# --- Optional ---
NIBRAS_ENABLE_DEMO_SEED=0
WORKER_POLL_INTERVAL_MS=2000

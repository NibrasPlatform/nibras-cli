DATABASE_URL=postgresql://nibras:nibras@127.0.0.1:5432/nibras?schema=public

# ── Redis / BullMQ (optional) ─────────────────────────────────────────────────
# When set, the API publishes new verification jobs to Redis instantly and the
# worker consumes them via BullMQ instead of polling the database every 2 s.
# Leave unset to use the built-in DB polling fallback (no Redis dependency).
# Format: redis://[:password@]host:port  or  rediss://... for TLS
REDIS_URL=
# Number of jobs the worker processes in parallel. Default: 1.
WORKER_CONCURRENCY=1

# ── Worker tuning (optional) ──────────────────────────────────────────────────
# DB-polling interval when REDIS_URL is not set. Default: 2000 (2 s).
WORKER_POLL_INTERVAL_MS=2000
# Port for the worker's internal /healthz endpoint. Default: 9090.
WORKER_HEALTH_PORT=9090
# Sandbox mode for student code. 'ulimit' enforces CPU/memory limits; 'none' skips them.
# Only use 'none' in trusted dev environments.
WORKER_SANDBOX_MODE=ulimit
# Maximum CPU seconds a verification run may consume. Default: 60.
WORKER_MAX_CPU_SECONDS=60
# Maximum virtual memory in MB for a verification run. Default: 512.
WORKER_MAX_MEM_MB=512

PORT=4848
HOST=127.0.0.1
NIBRAS_PROXY_HOST=127.0.0.1
NIBRAS_PROXY_PORT=8080
NIBRAS_LOCAL_API_ORIGIN=http://127.0.0.1:4848
NIBRAS_LOCAL_WEB_ORIGIN=http://127.0.0.1:3000
NIBRAS_API_STORE=tmp/nibras-api-store.json
NIBRAS_API_BASE_URL=http://127.0.0.1:4848
NIBRAS_WEB_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_NIBRAS_API_BASE_URL=http://127.0.0.1:4848
NEXT_PUBLIC_NIBRAS_WEB_BASE_URL=http://127.0.0.1:3000
# Optional comma-separated browser origins allowed to call the API directly.
# Leave unset to allow the configured web base URL plus local Next.js dev origins.
NIBRAS_WEB_CORS_ORIGINS=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# ── Email notifications (optional) ──────────────────────────────────────────
# Get a free API key at resend.com. When unset, email sending is silently disabled.
RESEND_API_KEY=
# Must be a verified sender domain in your Resend account.
NIBRAS_EMAIL_FROM=Nibras <noreply@yourdomain.com>

# ── Encryption ───────────────────────────────────────────────────────────────
# Required in production. Generate with: openssl rand -hex 32
NIBRAS_ENCRYPTION_KEY=

# ── Server tuning (optional) ──────────────────────────────────────────────────
# Fastify connection and request body timeouts in milliseconds.
# Defaults: 10000 (connection) / 30000 (request).
CONNECTION_TIMEOUT_MS=10000
REQUEST_TIMEOUT_MS=30000
# Per-IP or per-token rate limit (requests per minute). Default: 100.
RATE_LIMIT_MAX=100
# Maximum request body size in bytes. Default: 524288 (512 KB).
BODY_LIMIT_BYTES=524288
# Fastify log level: trace | debug | info | warn | error | fatal. Default: info.
LOG_LEVEL=info
# Expose Swagger UI at /docs and OpenAPI JSON at /docs/json in production.
# Always enabled in development. Set to "true" to enable in production.
NIBRAS_SWAGGER_ENABLED=false
# Optional bearer token to protect the /metrics endpoint in production.
# Leave unset for local dev. Generate: openssl rand -hex 16
NIBRAS_METRICS_TOKEN=

# ── Error monitoring (optional) ───────────────────────────────────────────────
# When SENTRY_DSN is set, the API and worker report errors to Sentry.
# Gracefully skipped when unset.
SENTRY_DSN=

# ── AI Grading (optional) ─────────────────────────────────────────────────────
# When NIBRAS_AI_API_KEY and NIBRAS_AI_MODEL are set, the worker automatically
# grades semantic questions after a successful verification run and pre-fills
# the instructor review form with confidence scores, criterion breakdowns,
# reasoning summaries, and evidence quotes.
# Omit both to disable AI grading entirely (no breaking change).
NIBRAS_AI_API_KEY=
NIBRAS_AI_MODEL=gpt-4o-mini
# Defaults to OpenAI. Override for compatible providers (Azure, Ollama, etc.)
NIBRAS_AI_BASE_URL=https://api.openai.com/v1
NIBRAS_AI_TIMEOUT_MS=30000
NIBRAS_AI_MAX_RETRIES=2
# Submissions with AI confidence below this threshold are flagged for human review
NIBRAS_AI_MIN_CONFIDENCE=0.8

DATABASE_URL=postgresql://praxis:praxis@127.0.0.1:5432/praxis?schema=public
PORT=4848
HOST=127.0.0.1
PRAXIS_PROXY_HOST=127.0.0.1
PRAXIS_PROXY_PORT=8080
PRAXIS_LOCAL_API_ORIGIN=http://127.0.0.1:4848
PRAXIS_LOCAL_WEB_ORIGIN=http://127.0.0.1:3000
PRAXIS_API_STORE=tmp/praxis-api-store.json
PRAXIS_API_BASE_URL=http://127.0.0.1:4848
PRAXIS_WEB_BASE_URL=http://127.0.0.1:3000
NEXT_PUBLIC_PRAXIS_API_BASE_URL=http://127.0.0.1:4848
NEXT_PUBLIC_PRAXIS_WEB_BASE_URL=http://127.0.0.1:3000
# Optional comma-separated browser origins allowed to call the API directly.
# Leave unset to allow the configured web base URL plus local Next.js dev origins.
PRAXIS_WEB_CORS_ORIGINS=
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_NAME=
GITHUB_WEBHOOK_SECRET=
GITHUB_TEMPLATE_OWNER=
GITHUB_TEMPLATE_REPO=

# ── AI Grading (optional) ─────────────────────────────────────────────────────
# When PRAXIS_AI_API_KEY and PRAXIS_AI_MODEL are set, the worker automatically
# grades semantic questions after a successful verification run and pre-fills
# the instructor review form with confidence scores, criterion breakdowns,
# reasoning summaries, and evidence quotes.
# Omit both to disable AI grading entirely (no breaking change).
PRAXIS_AI_API_KEY=
PRAXIS_AI_MODEL=gpt-4o-mini
# Defaults to OpenAI. Override for compatible providers (Azure, Ollama, etc.)
PRAXIS_AI_BASE_URL=https://api.openai.com/v1
PRAXIS_AI_TIMEOUT_MS=30000
PRAXIS_AI_MAX_RETRIES=2
# Submissions with AI confidence below this threshold are flagged for human review
PRAXIS_AI_MIN_CONFIDENCE=0.8
